              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function() {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/collectivities/999999",
              "host": ["{{base_url}}"],
              "path": ["collectivities", "999999"]
            }
          }
        },
        {
          "name": "POST Données invalides (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function() {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/collectivities",
              "host": ["{{base_url}}"],
              "path": ["collectivities"]
            }
          }
        },
        {
          "name": "GET Comptes avec date invalide",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 ou 200', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 422]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/collectivities/{{collectivity_id}}/financialAccounts?at=invalid-date",
              "host": ["{{base_url}}"],
              "path": ["collectivities", "{{collectivity_id}}", "financialAccounts"],
              "query": [
                {
                  "key": "at",
                  "value": "invalid-date"
                }
              ]
            }
          }
        }
      ]
    }
